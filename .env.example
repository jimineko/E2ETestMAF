MAF_QA_MODEL_PROVIDER=azure_openai

# Azure OpenAI (required when MAF_QA_MODEL_PROVIDER=azure_openai)
MAF_QA_AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
MAF_QA_AZURE_OPENAI_DEPLOYMENT=gpt-4o
MAF_QA_AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Gemini Developer API (required when MAF_QA_MODEL_PROVIDER=gemini)
MAF_QA_GEMINI_API_KEY=
MAF_QA_GEMINI_MODEL=gemini-2.5-flash-lite

# Vertex AI alternative. Set true and use ADC, or provide the API key above.
MAF_QA_GEMINI_USE_VERTEX_AI=false
MAF_QA_GEMINI_VERTEX_PROJECT=
MAF_QA_GEMINI_VERTEX_LOCATION=global

# GitHub Copilot / GitHub Models (required when MAF_QA_MODEL_PROVIDER=github_copilot)
# Prefer explicit token for non-interactive environments.
MAF_QA_GITHUB_COPILOT_TOKEN=
MAF_QA_GITHUB_COPILOT_MODEL=gpt-4.1
MAF_QA_GITHUB_COPILOT_BASE_URL=https://models.inference.ai.azure.com
# If true and token is empty, the runtime falls back to `gh auth token`.
MAF_QA_GITHUB_COPILOT_USE_GH_CLI_TOKEN=true

MAF_QA_TARGET_URL=https://example.com
MAF_QA_OBJECTIVE=Validate the critical user journey and report regressions.
MAF_QA_POLICIES=["No uncaught console errors","Primary journey completes successfully"]
MAF_QA_MAX_REFINEMENTS=2
MAF_QA_AGENT_CONFIG_DIR=agents
# Comma-separated read-only Skill directories. Example: skills/sample-app
MAF_QA_SKILL_PATHS=
MAF_QA_MODEL_RETRIES=2
MAF_QA_STRUCTURED_OUTPUT_RETRIES=1
MAF_QA_TRACE_CONTENT=false
MAF_QA_CODEACT_MODE=auto
MAF_QA_CODEACT_MAX_CODE_BYTES=32768
MAF_QA_CODEACT_MAX_INVOCATIONS=6
MAF_QA_CODEACT_REQUIRE_KVM=true
MAF_QA_CODEACT_ALLOW_FILE_UPLOAD=false
MAF_QA_CODEACT_ALLOW_DESTRUCTIVE_ACTIONS=false
MAF_QA_PLAYWRIGHT_HEADLESS=true
MAF_QA_PLAYWRIGHT_BROWSER=chrome
MAF_QA_PLAYWRIGHT_ALLOWED_ORIGINS=[]
MAF_QA_BLOB_ACCOUNT_URL=
MAF_QA_BLOB_CONTAINER=qa-artifacts
MAF_QA_OTLP_ENDPOINT=
MAF_QA_APPLICATIONINSIGHTS_CONNECTION_STRING=
MAF_QA_DEVUI_HOST=127.0.0.1
MAF_QA_DEVUI_PORT=8080
MAF_QA_DEVUI_AUTH_TOKEN=
