MAF_E2E_MODEL_PROVIDER=azure_openai

# Azure OpenAI (required when MAF_E2E_MODEL_PROVIDER=azure_openai)
MAF_E2E_AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
MAF_E2E_AZURE_OPENAI_DEPLOYMENT=gpt-4o
MAF_E2E_AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Gemini Developer API (required when MAF_E2E_MODEL_PROVIDER=gemini)
MAF_E2E_GEMINI_API_KEY=
MAF_E2E_GEMINI_MODEL=gemini-2.5-flash-lite

# Vertex AI alternative. Set true and use ADC, or provide the API key above.
MAF_E2E_GEMINI_USE_VERTEX_AI=false
MAF_E2E_GEMINI_VERTEX_PROJECT=
MAF_E2E_GEMINI_VERTEX_LOCATION=global

# GitHub Copilot / GitHub Models (required when MAF_E2E_MODEL_PROVIDER=github_copilot)
# Prefer explicit token for non-interactive environments.
MAF_E2E_GITHUB_COPILOT_TOKEN=
MAF_E2E_GITHUB_COPILOT_MODEL=gpt-4.1
MAF_E2E_GITHUB_COPILOT_BASE_URL=https://models.inference.ai.azure.com
# If true and token is empty, the runtime falls back to `gh auth token`.
MAF_E2E_GITHUB_COPILOT_USE_GH_CLI_TOKEN=true

MAF_E2E_TARGET_URL=https://example.com
MAF_E2E_OBJECTIVE=Validate the critical user journey and report regressions.
MAF_E2E_POLICIES=["No uncaught console errors","Primary journey completes successfully"]
MAF_E2E_MAX_REFINEMENTS=2
MAF_E2E_AGENT_CONFIG_DIR=agents
# Comma-separated read-only Skill directories. Example: skills/sample-app
MAF_E2E_SKILL_PATHS=
MAF_E2E_MODEL_RETRIES=2
MAF_E2E_STRUCTURED_OUTPUT_RETRIES=1
MAF_E2E_TRACE_CONTENT=false
MAF_E2E_CODEACT_MODE=auto
MAF_E2E_CODEACT_MAX_CODE_BYTES=32768
MAF_E2E_CODEACT_MAX_INVOCATIONS=6
MAF_E2E_CODEACT_REQUIRE_KVM=true
MAF_E2E_CODEACT_ALLOW_FILE_UPLOAD=false
MAF_E2E_CODEACT_ALLOW_DESTRUCTIVE_ACTIONS=false
# Compose launcher policy: auto | required | disabled
MAF_E2E_COMPOSE_KVM=auto
MAF_E2E_COMPOSE_HEADLESS=true
MAF_E2E_PLAYWRIGHT_HEADLESS=true
MAF_E2E_PLAYWRIGHT_BROWSER=chrome
MAF_E2E_PLAYWRIGHT_ALLOWED_ORIGINS=[]
MAF_E2E_BLOB_ACCOUNT_URL=
MAF_E2E_BLOB_CONTAINER=e2e-artifacts
MAF_E2E_OTLP_ENDPOINT=
MAF_E2E_APPLICATIONINSIGHTS_CONNECTION_STRING=
MAF_E2E_DEVUI_HOST=127.0.0.1
MAF_E2E_DEVUI_PORT=8080
MAF_E2E_DEVUI_AUTH_TOKEN=
